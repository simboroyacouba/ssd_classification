# =============================================================================
# Configuration SSD - Détection Toitures Cadastrales
# =============================================================================

CLASSES_FILE=classes.yaml

# =============================================================================
# DATASET
# =============================================================================

DETECTION_DATASET_IMAGES_DIR=../dataset1/images/default
DETECTION_DATASET_ANNOTATIONS_FILE=../dataset1/annotations/instances_default.json

# Dossier des images pour inférence
# Exemple Kaggle: DETECTION_INFERENCE_IMAGES_DIR=/kaggle/input/mon-dataset/test
DETECTION_INFERENCE_IMAGES_DIR=

# =============================================================================
# MODÈLE SSD
# =============================================================================

# Variantes disponibles:
#
#   ssd300_vgg16                    -> 300px fixe, backbone VGG16
#                                      ~26M params, précision maximale
#                                      GPU RAM: ~6 GB (batch=4)
#                                      ← recommandé pour la précision
#
#   ssdlite320_mobilenet_v3_large   -> 320px fixe, backbone MobileNetV3
#                                      ~3M params, léger et rapide
#                                      GPU RAM: ~3 GB (batch=4)
#                                      ← recommandé pour la vitesse
#
# ⚠️  La taille d'image est FIXE pour SSD (300px ou 320px selon le modèle).
#     IMAGE_SIZE est ignoré — il est déterminé automatiquement.

SSD_MODEL=ssd300_vgg16

# =============================================================================
# ENTRAÎNEMENT
# =============================================================================

NUM_EPOCHS=50
BATCH_SIZE=4
LEARNING_RATE=0.01
MOMENTUM=0.9
WEIGHT_DECAY=5e-4
GRAD_CLIP=1.0
TRAIN_SPLIT=0.70
VAL_SPLIT=0.20
TEST_SPLIT=0.10
SAVE_EVERY=5
PRETRAINED=true

# Seuil de confiance pour les détections
SCORE_THRESHOLD=0.3

# =============================================================================
# SORTIE
# =============================================================================

OUTPUT_DIR=./output
EVALUATION_DIR=./evaluation
PREDICTIONS_DIR=./predictions

# Chemin vers un modèle existant (pour evaluate.py et inference.py)
# Laisser vide pour auto-détection
# MODEL_PATH=./runs/detect/train/ssd_XXXXXXXX_XXXXXX/best_model.pth
